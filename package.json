{
  "name": "@ssi.developer/ssi-sdk",
  "version": "3.0.5",
  "description": "SSI SDK for Node.js – market data, trading and real-time streaming",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "keywords": [
    "ssi",
    "ssi-sdk",
    "vietnam",
    "stock",
    "trading",
    "market-data",
    "websocket",
    "streaming"
  ],
  "author": "SSI Securities Corporation",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  }
}